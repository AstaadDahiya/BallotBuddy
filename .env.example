# ──────────────────────────────────────────────
# BallotBuddy Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Google Gemini AI API Key (used by the local dev server)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps Embed API Key (used for polling station finder)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (get from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
